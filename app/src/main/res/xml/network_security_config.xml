<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default: HTTPS only. Probes to CDN edges are HTTPS. -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- WebView talks to the embedded server over http://127.0.0.1 -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

    <!-- ip-api.com free tier is HTTP-only; used to show the vantage IP (VPN check) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">ip-api.com</domain>
    </domain-config>
</network-security-config>
